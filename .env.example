# Sight2Sheet online-only feature credentials.
#
# All of these are optional. Without them, the app still runs the full
# offline fieldwork loop (rule-fallback config, Vosk-only STT, CSV export) —
# they only unlock the pre-mission LLM config and post-mission Sheets sync.
# Copy this file to .env.local and fill in what you have.

# Pre-mission NL -> CV Config (src/llm-config.ts). OpenRouter API key.
# https://openrouter.ai/keys
VITE_OPENROUTER_API_KEY=

# Online-mode STT upgrade (src/stt/deepgram-stt.ts). Deepgram API key.
# https://console.deepgram.com/
VITE_DEEPGRAM_API_KEY=

# Post-mission Google Sheets sync (src/log/sync.ts). OAuth2 client ID from
# a Google Cloud project with the Sheets API enabled (Google Identity
# Services token flow — a plain API key can't authorize writes).
# https://console.cloud.google.com/apis/credentials
VITE_GSHEETS_CLIENT_ID=
VITE_GSHEETS_SPREADSHEET_ID=
